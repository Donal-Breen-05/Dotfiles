{
    "layer": "top",
    "position": "top",
    "height": 40,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "reload_style_on_change": true,

    "modules-left": [
        "sway/workspaces"
    ],

    "modules-center": [],

    "modules-right": [
        "tray",
        "network",
        "pulseaudio",
        "backlight",
        "battery",
        "clock",
        "custom/notification"
    ],

    // в”Ђв”Ђ Left в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        }
    },

    // в”Ђв”Ђ Right в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
    "tray": {
        "icon-size": 16,
        "spacing": 8
    },
        
    
    "custom/notification": {
        "exec": "makoctl list | grep -c 'id'",
        "interval": 2,
        "format": "рџ”” {}",
        "on-click": "makoctl invoke",
        "on-click-right": "makoctl dismiss --all"
    },
    
    "network": {
        "format-wifi": "у°¤Ё",
        "format-ethernet": "у°€Ђ",
        "format-disconnected": "у°¤­",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "tooltip-format-ethernet": "{ifname}",
        "tooltip-format-disconnected": "Disconnected",
        "on-click": "bash -c 'if command -v nm-connection-editor &>/dev/null; then nm-connection-editor; elif command -v wl-wifi &>/dev/null; then wl-wifi; else foot nmtui; fi'"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "у°ќџ",
        "format-icons": {
            "default": ["у°•ї", "у°–Ђ", "у°•ѕ"]
        },
        "tooltip-format": "Volume: {volume}%",
        "on-click": "bash -c 'if command -v pavucontrol &>/dev/null; then pavucontrol; else foot pulsemixer; fi'",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
    },

    "backlight": {
        "format": "{icon} {percent}%" ,
        "format-icons": ["у°ѓћ", "у°ѓџ", "у°ѓ "],
        "tooltip-format": "Brightness: {percent}%",
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-",
        "on-click": "bash -c 'if command -v wdisplays &>/dev/null; then wdisplays; else foot brightnessctl; fi'"
    },

    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "у°‚„",
        "format-plugged": "у°љҐ",
        "format-icons": ["у°Ѓє", "у°Ѓ»", "у°Ѓј", "у°ЃЅ", "у°Ѓѕ", "у°Ѓї", "у°‚Ђ", "у°‚Ѓ", "у°‚‚", "у°Ѓ№"],
        "tooltip-format": "{capacity}% вЂ” {timeTo}",
        "states": {
            "critical": 15,
            "warning": 30
        }
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>",
        "interval": 1
    }
}
