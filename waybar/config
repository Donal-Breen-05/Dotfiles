{
    "layer": "top",
    "position": "top",
    "height": 42,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "reload_style_on_change": true,

    "modules-left": [
        "sway/workspaces",
        "custom/playerctl"
    ],

    "modules-center": [],

    "modules-right": [
        "custom/power-profile",
        "custom/notifications",
        "tray",
        "pulseaudio",
        "backlight",
        "battery",
        "clock"
    ],

    // ── Left ──────────────────────────────────────────────────────────────
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "format": "{name}",
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        }
    },

    "custom/playerctl": {
        "exec": "~/.config/waybar/scripts/playerctl.sh",
        "interval": 1,
        "return-type": "json",
        "on-click": "playerctl play-pause",
        "on-click-right": "playerctl next",
        "on-scroll-up": "playerctl previous"
    },

    // ── Right ─────────────────────────────────────────────────────────────
    "custom/power-profile": {
        "exec": "~/.config/waybar/scripts/power_profiles.sh --status",
        "interval": 2,
        "on-click": "~/.config/waybar/scripts/power_profiles.sh --cycle",
        "return-type": "json",
        "tooltip": true
    },

    "custom/notifications": {
        "exec": "~/.config/waybar/scripts/notif.sh",
        "interval": 2,
        "on-click": "swaync-client -t",
        "on-click-right": "swaync-client -d"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    // ── Audio ─────────────────────────────────────────────────────────────
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰝟 {volume}%",
        "format-icons": {
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "tooltip-format": "Volume: {volume}%",
        "on-click": "bash -c 'if command -v pavucontrol &>/dev/null; then pavucontrol; else foot pulsemixer; fi'",
        "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +5%",
        "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -5%"
    },

    // ── Brightness ───────────────────────────────────────────────────────
    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["󰃞", "󰃟", "󰃠"],
        "tooltip-format": "Brightness: {percent}%",
        "on-scroll-up": "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    // ── Battery ───────────────────────────────────────────────────────────
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": "󰚥 {capacity}%",
        "format-icons": [
            "󰁺", "󰁻", "󰁼", "󰁽", "󰁾",
            "󰁿", "󰂀", "󰂁", "󰂂", "󰁹"
        ],
        "tooltip-format": "{capacity}% — {timeTo}",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },

    // ── Clock ─────────────────────────────────────────────────────────────
    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt>{calendar}</tt>",
        "interval": 1
    }
}
